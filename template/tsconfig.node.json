{
  "include": ["vite.config.*", "vitest.config.*"],
  // Self-contained on purpose: we don't extend @tsconfig/node22 because its
  // floating "lib" (es2024) isn't recognised by the pinned TypeScript and a
  // child `lib` override can't suppress that parse-time error. These options
  // cover everything needed to type-check the Vite/Vitest config files.
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["node"]
  }
}
