# ─── SERVER-ONLY (no VITE_ prefix) ──────────────────────────────────────────
# Read by the dev proxy (vite.config.ts) and the production server (server.mjs)
# to authenticate API calls. NEVER bundled into the browser. Copy this file to
# .env.local and fill in your real values.
CONCIAR_API_URL=https://api.conciar.com
CONCIAR_API_KEY=your_api_key_here
CONCIAR_SALES_CHANNEL_KEY=your_sales_channel_key_here

# Port the production server (`npm start`) listens on. Optional; defaults to 3000.
# PORT=3000

# ─── BROWSER-SAFE (VITE_ prefix) ─────────────────────────────────────────────
# These are embedded in the JS bundle — never put secrets here.

# Shop display name (logo, footer, copyright, loading screen).
VITE_SHOP_NAME=My Shop

# Set to any non-empty value to enable real API calls (switches off mock mode).
VITE_CONCIAR_API_URL=https://api.conciar.com

# Public URL of this shop.
VITE_APP_URL=http://localhost:5173
